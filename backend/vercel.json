{
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/testexpress", "dest": "/api/testexpress.js" },
    { "src": "/api/test", "dest": "/api/test.js" },
    { "src": "/api/testapp", "dest": "/api/testapp.js" },
    { "src": "/api/testdb", "dest": "/api/testdb.js" },
    { "src": "/api/testlibsql", "dest": "/api/testlibsql.js" },
    { "src": "/api/(.*)", "dest": "/api/index.js" }
  ]
}
